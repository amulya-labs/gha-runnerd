# Auto-generated by Ansible. Do not edit manually.
# Template: examples/ansible/templates/config.yml.j2

github:
  scope: "{{ gha_github_scope | default('org') }}"
{% if gha_github_scope | default('org') == 'enterprise' %}
  enterprise: "{{ gha_github_enterprise }}"
{% else %}
  org: "{{ gha_github_org }}"
{% endif %}
  prefix: "{{ gha_github_prefix }}"
{% if gha_github_runner_group is defined %}
  runner_group:
    name: "{{ gha_github_runner_group }}"
{% endif %}

host:
  label: "{{ gha_host_label | default(inventory_hostname) }}"
  runner_base: "{{ gha_runner_base | default('/srv/gha') }}"
  docker_socket: "{{ gha_docker_socket | default('/var/run/docker.sock') }}"
  docker_user_uid: {{ gha_uid | default(1003) }}
  docker_user_gid: {{ gha_gid | default(1003) }}

cache:
  base_dir: "{{ gha_cache_dir | default('/srv/gha-cache') }}"
  permissions: "755"

runners:
{% for runner in gha_runners | from_json %}
  - "{{ runner }}"
{% endfor %}

sizes:
  xs:
    cpus: 1.0
    mem_limit: "2g"
    pids_limit: 1024
  small:
    cpus: 2.0
    mem_limit: "4g"
    pids_limit: 2048
  medium:
    cpus: 6.0
    mem_limit: "16g"
    pids_limit: 4096
  large:
    cpus: 12.0
    mem_limit: "32g"
    pids_limit: 8192
  max:
    cpus: null
    mem_limit: null
    pids_limit: null

runner:
  version: "{{ runner_version | default('2.329.0') }}"
  arch: "{{ runner_arch | default('linux-x64') }}"

systemd:
  restart_policy: "always"
  restart_sec: 10

sudoers:
  path: "/etc/sudoers.d/gha-runner-cleanup"

{% if gha_metrics_enabled | default(false) %}
metrics:
  textfile_path: "{{ gha_metrics_path | default('/var/lib/prometheus/node-exporter/gha-runners.prom') }}"
{% endif %}
